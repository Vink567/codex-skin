{
  "name": "codex-skin-studio",
  "version": "0.1.4",
  "description": "Import, edit, apply, and restore validated Codex theme resource packages.",
  "main": "src/main.cjs",
  "scripts": {
    "generate-icon": "node scripts/generate-app-icon.cjs",
    "start": "npm run generate-icon && electron .",
    "dist": "npm run generate-icon && electron-builder --win portable"
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.vink.codexskinstudio",
    "productName": "Codex Skin Studio",
    "artifactName": "Codex-Skin-Studio-${version}-portable.exe",
    "directories": {
      "output": "../dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "build/app-icon.ico",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../codex-skin-runtime",
        "to": "codex-skin-runtime"
      }
    ],
    "win": {
      "icon": "build/app-icon.ico",
      "target": ["portable"]
    }
  }
}
